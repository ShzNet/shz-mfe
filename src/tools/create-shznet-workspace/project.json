{
  "name": "create-shznet-workspace",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "root": "tools/create-shznet-workspace",
  "sourceRoot": "tools/create-shznet-workspace",
  "tags": ["scope:tooling", "type:cli", "publishable"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "pnpm build",
        "cwd": "{projectRoot}"
      }
    },
    "nx-release-publish": {
      "executor": "@nx/js:release-publish",
      "dependsOn": ["build"],
      "options": {
        "packageRoot": "{projectRoot}/dist",
        "registry": "https://registry.npmjs.org"
      }
    }
  }
}
